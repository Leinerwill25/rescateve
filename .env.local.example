# Copia este archivo a .env.local y rellena con tus valores de Supabase
# (Supabase > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# Tuia911 — API de acopio (solo servidor, panel admin)
TUIA911_API_KEY=tu_api_key_de_tuia911
# TUIA911_API_BASE=https://api.tuia911.com

# Ash — asistente conversacional (solo servidor)
GEMINI_API_KEY=tu_api_key_de_google_gemini

# Service role — necesaria para registrar tickets desde Ash y otras rutas admin
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
